#!/bin/sh
set -e

BASE="/usr/local/apt-native"
RUNTIME="$BASE/runtime"
BIN="$RUNTIME/usr/bin"
LIB="$RUNTIME/usr/lib/x86_64-linux-gnu"
LIB2="$RUNTIME/lib/x86_64-linux-gnu"
TMP="$BASE/tmp"

DEBIAN_MIRROR="${APT_NATIVE_MIRROR:-https://mirrors.tuna.tsinghua.edu.cn/debian}"
DEBIAN_SECURITY_MIRROR="${APT_NATIVE_SECURITY_MIRROR:-https://mirrors.tuna.tsinghua.edu.cn/debian-security}"
DEBIAN_SUITE="bookworm"
DEBIAN_COMPONENT="main"
DEBIAN_ARCH="amd64"

usage() {
  cat <<USAGE
Usage:
  apt-native-bootstrap                          # bootstrap native apt runtime + host apt dirs
  apt-native-bootstrap --exec <apt|apt-get|dpkg> [args...]

Behavior:
  - Physical host mode only (no Docker backend).
  - Auto-installs a minimal Debian apt/dpkg runtime under:
      $RUNTIME

WARNING:
  This is experimental and can modify DSM system files.
USAGE
}

runtime_ready() {
  [ -x "$BIN/apt" ] && [ -x "$BIN/apt-get" ] && [ -x "$BIN/dpkg" ]
}

ensure_host_apt_layout() {
  mkdir -p /etc/apt/sources.list.d
  mkdir -p /var/lib/apt/lists/partial
  mkdir -p /var/cache/apt/archives/partial
  mkdir -p /var/lib/dpkg
  [ -f /var/lib/dpkg/status ] || touch /var/lib/dpkg/status

  if [ ! -s /etc/apt/sources.list ]; then
    cat > /etc/apt/sources.list <<SRC
deb ${DEBIAN_MIRROR} bookworm main contrib non-free non-free-firmware
deb ${DEBIAN_MIRROR} bookworm-updates main contrib non-free non-free-firmware
deb ${DEBIAN_SECURITY_MIRROR} bookworm-security main contrib non-free non-free-firmware
SRC
  fi
}

get_pkg_filename() {
  pkg="$1"
  index_url="$DEBIAN_MIRROR/dists/$DEBIAN_SUITE/$DEBIAN_COMPONENT/binary-$DEBIAN_ARCH/Packages.gz"
  index_gz="$TMP/Packages.gz"

  mkdir -p "$TMP"
  curl -fsSL "$index_url" -o "$index_gz"
  gzip -dc "$index_gz" | awk -v p="$pkg" '
    BEGIN { RS=""; FS="\n" }
    $1 == "Package: " p {
      for (i = 1; i <= NF; i++) {
        if ($i ~ /^Filename: /) {
          print substr($i, 11);
          exit;
        }
      }
    }
  '
}

extract_deb_data() {
  deb_file="$1"
  out_dir="$2"
  work_dir="$3"

  mkdir -p "$work_dir"

  if command -v ar >/dev/null 2>&1; then
    (cd "$work_dir" && ar x "$deb_file" >/dev/null)
  elif command -v bsdtar >/dev/null 2>&1; then
    (cd "$work_dir" && bsdtar -xf "$deb_file")
  elif command -v busybox >/dev/null 2>&1 && busybox ar --help >/dev/null 2>&1; then
    (cd "$work_dir" && busybox ar x "$deb_file" >/dev/null)
  elif command -v python3 >/dev/null 2>&1; then
    python3 - "$deb_file" "$work_dir" <<'PY'
import os,sys
src,out = sys.argv[1], sys.argv[2]
with open(src,'rb') as f:
    if f.read(8) != b'!<arch>\n':
        raise SystemExit('invalid ar archive')
    while True:
        h=f.read(60)
        if not h:
            break
        if len(h)<60:
            raise SystemExit('truncated ar header')
        name=h[:16].decode('utf-8','ignore').strip()
        size=int(h[48:58].decode('ascii','ignore').strip() or '0')
        data=f.read(size)
        if size%2==1:
            f.read(1)
        name=name.rstrip('/')
        if name in ('data.tar.xz','data.tar.gz','data.tar.zst','data.tar'):
            with open(os.path.join(out,name),'wb') as w:
                w.write(data)
PY
  else
    echo "[apt-native] missing extractor: need one of ar / bsdtar / busybox ar / python3" >&2
    return 1
  fi

  if [ -f "$work_dir/data.tar.xz" ]; then
    tar -xJf "$work_dir/data.tar.xz" -C "$out_dir"
  elif [ -f "$work_dir/data.tar.gz" ]; then
    tar -xzf "$work_dir/data.tar.gz" -C "$out_dir"
  elif [ -f "$work_dir/data.tar.zst" ]; then
    if command -v unzstd >/dev/null 2>&1; then
      unzstd -c "$work_dir/data.tar.zst" | tar -xf - -C "$out_dir"
    elif command -v zstd >/dev/null 2>&1; then
      zstd -dc "$work_dir/data.tar.zst" | tar -xf - -C "$out_dir"
    else
      echo "[apt-native] data.tar.zst found but zstd/unzstd is missing" >&2
      return 1
    fi
  elif [ -f "$work_dir/data.tar" ]; then
    tar -xf "$work_dir/data.tar" -C "$out_dir"
  else
    echo "[apt-native] unsupported deb payload format: $deb_file" >&2
    return 1
  fi
}

install_runtime_pkg() {
  pkg="$1"
  filename="$(get_pkg_filename "$pkg")"
  if [ -z "$filename" ]; then
    echo "[apt-native] package not found in index: $pkg" >&2
    return 1
  fi

  deb_url="$DEBIAN_MIRROR/$filename"
  deb_path="$TMP/${pkg}.deb"
  work_dir="$TMP/extract-$pkg"

  rm -rf "$work_dir"
  mkdir -p "$TMP" "$RUNTIME"
  echo "[apt-native] fetching $pkg"
  curl -fL "$deb_url" -o "$deb_path"
  extract_deb_data "$deb_path" "$RUNTIME" "$work_dir"
}

bootstrap_runtime() {
  if runtime_ready; then
    return 0
  fi

  if [ "$(id -u)" != "0" ]; then
    echo "[apt-native] runtime missing and bootstrap requires root" >&2
    exit 1
  fi

  mkdir -p "$BASE" "$RUNTIME" "$TMP"
  ensure_host_apt_layout

  # Minimal runtime set for apt/apt-get/dpkg on x64.
  PKGS="\
libc6 libgcc-s1 libstdc++6 zlib1g libbz2-1.0 liblzma5 liblz4-1 libzstd1 \
libgpg-error0 libgcrypt20 libsystemd0 libudev1 libseccomp2 libapt-pkg6.0 \
gpgv apt dpkg"

  for p in $PKGS; do
    install_runtime_pkg "$p"
  done

  rm -rf "$TMP"
  echo "[apt-native] runtime bootstrap done"
}

exec_with_runtime() {
  cmd="$1"; shift
  export LD_LIBRARY_PATH="$LIB:$LIB2:${LD_LIBRARY_PATH}"
  export PATH="$BIN:${PATH}"

  case "$cmd" in
    apt|apt-get)
      exec "$BIN/$cmd" \
        -o Dir::Etc=/etc/apt \
        -o Dir::Etc::sourcelist=/etc/apt/sources.list \
        -o Dir::Etc::sourceparts=/etc/apt/sources.list.d \
        -o Dir::State=/var/lib/apt \
        -o Dir::Cache=/var/cache/apt \
        "$@"
      ;;
    dpkg)
      exec "$BIN/dpkg" "$@"
      ;;
    *)
      echo "[apt-native] unsupported command: $cmd" >&2
      exit 2
      ;;
  esac
}

if [ "$1" = "--exec" ]; then
  shift
  cmd="$1"; shift || true
  [ -n "$cmd" ] || { usage; exit 2; }
  bootstrap_runtime
  exec_with_runtime "$cmd" "$@"
fi

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

if [ "$(id -u)" != "0" ]; then
  echo "[apt-native] bootstrap requires root" >&2
  exit 1
fi

mkdir -p "$BASE" "$RUNTIME"
ensure_host_apt_layout
bootstrap_runtime

cat > "$BASE/README.txt" <<TXT
APT Native experimental runtime
- Physical host mode only (no Docker backend).
- Native runtime installed under:
  $RUNTIME
TXT

echo "[apt-native] bootstrap complete"
echo "[apt-native] now try: apt update"
