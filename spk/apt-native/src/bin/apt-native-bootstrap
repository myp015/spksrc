#!/bin/sh
set -e

BASE="/usr/local/apt-native"
RUNTIME="$BASE/runtime"
BIN="$RUNTIME/usr/bin"
LIB="$RUNTIME/usr/lib/x86_64-linux-gnu"
LIB2="$RUNTIME/lib/x86_64-linux-gnu"

usage() {
  cat <<USAGE
Usage:
  apt-native-bootstrap                          # initialize apt-native state files
  apt-native-bootstrap --exec <apt|apt-get|dpkg> [args...]

Behavior:
  - Physical host only (no Docker backend).
  - Requires native runtime binaries under:
      $RUNTIME

WARNING:
  This is experimental and can modify DSM system files.
USAGE
}

run_via_native_runtime() {
  cmd="$1"; shift
  [ -x "$BIN/$cmd" ] || return 1
  export LD_LIBRARY_PATH="$LIB:$LIB2:${LD_LIBRARY_PATH}"
  exec "$BIN/$cmd" "$@"
}

ensure_host_apt_layout() {
  mkdir -p /etc/apt/sources.list.d
  mkdir -p /var/lib/apt/lists/partial
  mkdir -p /var/cache/apt/archives/partial
  mkdir -p /var/lib/dpkg
  [ -f /var/lib/dpkg/status ] || touch /var/lib/dpkg/status

  # Create default sources only when sources.list is missing/empty.
  if [ ! -s /etc/apt/sources.list ]; then
    cat > /etc/apt/sources.list <<'SRC'
deb http://deb.debian.org/debian bookworm main contrib non-free non-free-firmware
deb http://deb.debian.org/debian bookworm-updates main contrib non-free non-free-firmware
deb http://security.debian.org/debian-security bookworm-security main contrib non-free non-free-firmware
SRC
  fi
}

if [ "$1" = "--exec" ]; then
  shift
  cmd="$1"; shift || true
  [ -n "$cmd" ] || { usage; exit 2; }
  run_via_native_runtime "$cmd" "$@" || {
    echo "[apt-native] runtime not initialized." >&2
    echo "[apt-native] place native apt/dpkg runtime under: $RUNTIME" >&2
    echo "[apt-native] then rerun command: apt update" >&2
    exit 1
  }
fi

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

if [ "$(id -u)" != "0" ]; then
  echo "[apt-native] bootstrap requires root" >&2
  exit 1
fi

mkdir -p "$BASE" "$RUNTIME"
ensure_host_apt_layout
cat > "$BASE/README.txt" <<TXT
APT Native experimental runtime
- Physical host mode only (no Docker backend).
- Host apt state dirs are initialized.
- Provide native apt/dpkg runtime binaries under:
  $RUNTIME
TXT

echo "[apt-native] bootstrap complete"
echo "[apt-native] host apt directories initialized"
echo "[apt-native] runtime path: $RUNTIME"
