{
  "meta": {
    "lastTouchedVersion": "2026.4.1",
    "lastTouchedAt": "2026-04-15T14:41:38.065Z"
  },
  "update": {
    "checkOnStart": false
  },
  "browser": {
    "headless": true,
    "noSandbox": true,
    "defaultProfile": "openclaw"
  },
  "models": {
    "mode": "merge",
    "providers": {}
  },
  "agents": {
    "defaults": {
      "compaction": {
        "mode": "safeguard"
      },
      "sandbox": {
        "mode": "off",
        "workspaceAccess": "none",
        "scope": "agent"
      },
      "elevatedDefault": "full",
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "workspace": "/volume1/openclaw"
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions",
    "tts": {
      "auto": "off",
      "mode": "final",
      "provider": "microsoft",
      "providers": {
        "microsoft": {
          "voice": "zh-CN-XiaoxiaoNeural",
          "lang": "zh-CN",
          "outputFormat": "ogg-24khz-16bit-mono-opus",
          "pitch": "+0Hz",
          "rate": "+0%",
          "volume": "+0%",
          "timeoutMs": 30000
        }
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },
  "skills": {
    "entries": {
      "browser-automation": { "enabled": true },
      "brave-search": { "enabled": true },
      "weather": { "enabled": true },
      "news-summary": { "enabled": true },
      "taskflow": { "enabled": true },

      "session-logs": { "enabled": false },
      "tmux": { "enabled": false },
      "slack": { "enabled": false },
      "discord": { "enabled": false },
      "notion": { "enabled": false },
      "sag": { "enabled": false },
      "openai-whisper": { "enabled": false },
      "openai-whisper-api": { "enabled": false }
    }
  },
  "tools": {
    "profile": "full",
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "webchat": ["*"],
        "feishu": ["*"],
        "dingtalk": ["*"],
        "qqbot": ["*"]
      }
    },
    "sessions": {
      "visibility": "all"
    },
    "fs": {
      "workspaceOnly": true
    }
  },
  "channels": {
    "feishu": {
      "enabled": false,
      "defaultAccount": "default",
      "accounts": {
        "default": {}
      },
      "dmPolicy": "open",
      "groupPolicy": "open",
      "allowFrom": [
        "*"
      ]
    },
    "qqbot": {
      "enabled": false,
      "dmPolicy": "open",
      "groupPolicy": "open",
      "allowFrom": [
        "*"
      ]
    },
    "dingtalk": {
      "enabled": false,
      "dmPolicy": "open",
      "groupPolicy": "open",
      "allowFrom": [
        "*"
      ]
    },
    "wecom": {
      "enabled": false,
      "dmPolicy": "open",
      "groupPolicy": "open",
      "allowFrom": [
        "*"
      ],
      "dynamicAgents": {
        "enabled": false
      },
      "dm": {
        "createAgentOnFirstMessage": false
      }
    },
    "openclaw-weixin": {
      "enabled": false
    }
  },
  "plugins": {
    "entries": {
      "browser": {
        "enabled": true
      },
      "feishu": {
        "enabled": false
      },
      "qqbot": {
        "enabled": false
      },
      "dingtalk": {
        "enabled": false
      },
      "wecom": {
        "enabled": false
      },
      "openclaw-weixin": {
        "enabled": false
      }
    },
    "enabled": true,
    "bundledDiscovery": "allowlist",
    "allow": [
      "browser"
    ]
  },
  "memory": {
    "backend": "builtin",
    "citations": "auto",
    "qmd": {
      "includeDefaultMemory": true,
      "sessions": {
        "enabled": true
      },
      "limits": {
        "timeoutMs": 8000,
        "maxResults": 16
      },
      "update": {
        "onBoot": true,
        "interval": "5m",
        "debounceMs": 15000
      },
      "command": "/usr/local/bin/qmd",
      "paths": [
        {
          "path": "/volume1/openclaw/.openclaw",
          "name": "workspace",
          "pattern": "**/*.md"
        }
      ]
    }
  },
  "gateway": {
    "port": 58789,
    "bind": "lan",
    "mode": "local",
    "controlUi": {
      "basePath": "/default",
      "allowedOrigins": [
        "*"
      ],
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "123456"
    }
  }
}
